   "source": [
    "# 세 정수를 입력받아 최댓값 구하기\n",
    "\n",
    "print('세 정수의 최댓값을 구합니다')    \n",
    "a = input('정수 a의 값을 입력하세요')\n",
    "b = input('정수 b의 값을 입력하세요')\n",
    "c = input('정수 c의 값을 입력하세요')\n",
    "\n",
    "max = a\n",
    "#조건식으로 평가한 결과에 따라 프로그램의 실행 흐름이 변경되는데 이러한 구조를 선태구조라 한다\n",
    "if b > max : \n",
    "    max = b\n",
    "if c > max : \n",
    "    max = c\n",
    "\n",
    "print(f'최댓값은 {max}입니다')"
   ]
